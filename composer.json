{
    "name": "kyosonline/php-k8s",
    "description": "Control your Kubernetes clusters with this PHP-based Kubernetes client. It supports any form of authentication, the exec API, and it has an easy implementation for CRDs.",
    "keywords": [
        "laravel",
        "php",
        "kubernetes",
        "k8s",
        "k3s",
        "k0s",
        "cluster",
        "api",
        "kubeadm",
        "kubeapi",
        "kube",
        "fork"
    ],
    "license": "Apache-2.0",
    "homepage": "https://github.com/renoki-co/php-k8s",
    "authors": [
        {
            "name": "Alex Renoki",
            "homepage": "https://github.com/rennokki",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4|^8.5",
        "ext-json": "*",
        "composer/semver": "^3.4",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/macroable": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "ratchet/pawl": "^0.4.1",
        "symfony/process": "^6.0|^7.0"
    },
    "suggest": {
        "ext-yaml": "YAML extension is used to read or generate YAML from PHP K8s internal classes."
    },
    "autoload": {
        "psr-4": {
            "RenokiCo\\PhpK8s\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RenokiCo\\PhpK8s\\Test\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "pint": "pint"
    },
    "require-dev": {
        "laravel/pint": "^1.25",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
