{
    "preset": "psr12",
    "rules": {
        "concat_space": {
            "spacing": "one"
        },
        "no_extra_blank_lines": {
            "tokens": [
                "square_brace_block"
            ]
        },
        "not_operator_with_successor_space": true,
        "ordered_imports": {
            "case_sensitive": true
        },
        "ordered_traits": {
            "case_sensitive": true
        },
        "single_quote": {
            "strings_containing_single_quote_chars": false
        }
    }
}
